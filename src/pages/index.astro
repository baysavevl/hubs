---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ChatBot from "../components/ChatBot.astro";

const base = import.meta.env.BASE_URL;

const allPosts = await getCollection("blog");
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = await getCollection("projects");
const featuredProjects = projects.filter(p => p.data.featured);
---

<BaseLayout title="Home" wide={true}>
  <!-- Hero -->
  <section class="hero-section">
    <div class="google-bar"><span></span><span></span><span></span><span></span></div>
    <h1 class="hero-title">
      Google Ads<br/>
      <span class="hero-highlight">Solutions Architect</span>
    </h1>
    <p class="hero-subtitle">
      I help you plan, build, and optimize Google Ads campaigns.<br class="hidden sm:block"/>
      Ask me anything or explore the knowledge base.
    </p>
  </section>

  <!-- Chat -->
  <section class="chat-section">
    <ChatBot />
  </section>

  <!-- Featured Resources -->
  <section class="resources-section">
    <h2 class="section-heading">Featured Resources</h2>
    <div class="resources-grid">
      <a href={`${base}projects/google-ads/`} class="resource-card resource-primary">
        <span class="resource-icon">📖</span>
        <h3>Complete Google Ads Guide</h3>
        <p>Everything from account setup to advanced optimization — your comprehensive reference.</p>
        <span class="resource-link">Read the guide &rarr;</span>
      </a>
      <a href={`${base}success-story`} class="resource-card">
        <span class="resource-icon">🌏</span>
        <h3>SEA Success Stories</h3>
        <p>Real case studies from Vietnam, Thailand, Indonesia, and more.</p>
        <span class="resource-link">View stories &rarr;</span>
      </a>
      <a href={`${base}projects`} class="resource-card">
        <span class="resource-icon">🗂️</span>
        <h3>Knowledge Library</h3>
        <p>Organized guides and topics covering every aspect of Google Ads.</p>
        <span class="resource-link">Browse library &rarr;</span>
      </a>
    </div>
  </section>

  <!-- Recent Case Studies -->
  {recentPosts.length > 0 && (
    <section class="recent-section">
      <div class="section-header">
        <h2 class="section-heading">Latest Success Stories</h2>
        <a href={`${base}success-story`} class="section-link">View all &rarr;</a>
      </div>
      <div class="recent-grid">
        {recentPosts.map((post) => (
          <a href={`${base}success-story/${post.id}`} class="recent-card">
            {post.data.metric && (
              <span class="recent-metric">{post.data.metric}</span>
            )}
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.country && (
              <span class="recent-country">{post.data.country} | {post.data.industry}</span>
            )}
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .hero-section {
    text-align: center;
    padding: 3rem 0 2rem;
  }

  .google-bar {
    display: flex;
    height: 4px;
    border-radius: 2px;
    overflow: hidden;
    max-width: 80px;
    margin: 0 auto 2rem;
  }

  .google-bar span { flex: 1; }
  .google-bar span:nth-child(1) { background: var(--color-google-blue); }
  .google-bar span:nth-child(2) { background: var(--color-google-red); }
  .google-bar span:nth-child(3) { background: var(--color-google-yellow); }
  .google-bar span:nth-child(4) { background: var(--color-google-green); }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-text);
    margin: 0;
  }

  .hero-highlight {
    background: linear-gradient(135deg, #4285f4, #34a853);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    margin: 1rem auto 0;
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 480px;
    line-height: 1.6;
  }

  .chat-section {
    max-width: 700px;
    margin: 2rem auto 0;
  }

  .resources-section {
    margin-top: 4rem;
  }

  .section-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.25rem;
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .resource-card {
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    transition: box-shadow 0.2s, transform 0.2s;
    display: block;
  }

  .resource-card:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .resource-primary {
    border-color: var(--color-google-blue);
    border-width: 2px;
  }

  .resource-icon {
    font-size: 1.75rem;
    display: block;
    margin-bottom: 0.75rem;
  }

  .resource-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.5rem;
  }

  .resource-card p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.6;
  }

  .resource-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-google-blue);
  }

  .recent-section {
    margin-top: 3.5rem;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .section-header .section-heading {
    margin: 0;
  }

  .section-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-google-blue);
    text-decoration: none;
  }

  .section-link:hover {
    text-decoration: underline;
  }

  .recent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1rem;
  }

  .recent-card {
    background: var(--color-bg-subtle);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    text-decoration: none;
    transition: border-color 0.15s;
    display: block;
  }

  .recent-card:hover {
    border-color: var(--color-google-blue);
  }

  .recent-metric {
    display: inline-block;
    background: #e6f4ea;
    color: #137333;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    margin-bottom: 0.5rem;
  }

  .recent-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 0.35rem;
    line-height: 1.4;
  }

  .recent-card p {
    font-size: 0.825rem;
    color: var(--color-text-muted);
    margin: 0 0 0.5rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .recent-country {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: 2rem;
    }
  }
</style>
