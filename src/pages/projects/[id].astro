---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TableOfContents from "../../components/TableOfContents.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const hasHeadings = headings && headings.length > 0;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <nav class="mb-6 text-sm text-[var(--color-text-muted)]">
    <a href={`${base}projects`} class="hover:text-[var(--color-accent)]">Projects</a>
    <span class="mx-2">/</span>
    <span class="text-[var(--color-text)]">{project.data.title}</span>
  </nav>

  <article>
    {hasHeadings ? (
      <div class="project-layout">
        <div class="project-content prose prose-gray max-w-none">
          <Content />
        </div>
        <TableOfContents headings={headings} />
      </div>
    ) : (
      <div class="prose prose-gray max-w-none">
        <Content />
      </div>
    )}
  </article>
</BaseLayout>

<style>
  .project-layout {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
  }

  .project-content {
    flex: 1;
    min-width: 0;
  }

  @media (max-width: 1023px) {
    .project-layout {
      display: block;
    }
  }
</style>

{hasHeadings && (
  <style is:global>
    main {
      max-width: 64rem !important;
    }
  </style>
)}
