---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}

const { title, description = "Google Ads Solutions Architect — helping businesses succeed with Google Ads.", wide = false } = Astro.props;
const siteTitle = `${title} | Google Ads Solutions Architect`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <meta name="generator" content={Astro.generator} />
    <title>{siteTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <Header />
    <main class:list={[
      "mx-auto w-full flex-1 px-6 py-12",
      wide ? "max-w-6xl" : "max-w-3xl",
    ]}>
      <slot />
    </main>
    <Footer />
  </body>
</html>
