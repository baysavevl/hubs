---
interface Props {
  countryCounts: Record<string, number>;
}

const { countryCounts } = Astro.props;

const countries = [
  { id: 'Vietnam', label: 'Vietnam', short: 'VN' },
  { id: 'Thailand', label: 'Thailand', short: 'TH' },
  { id: 'Indonesia', label: 'Indonesia', short: 'ID' },
  { id: 'Malaysia', label: 'Malaysia', short: 'MY' },
  { id: 'Philippines', label: 'Philippines', short: 'PH' },
  { id: 'Singapore', label: 'Singapore', short: 'SG' },
];

const countryCountsJSON = JSON.stringify(countryCounts);
---

<div class="sea-map-container">
  <div class="map-wrapper">
    <div id="sea-map" style="width: 100%; height: 400px; border-radius: 12px; border: 1px solid var(--color-border); z-index: 1;"></div>
  </div>

  <!-- Country tabs below map -->
  <div class="country-tabs" id="country-tabs">
    <button class="country-tab active" data-country="All">
      All Countries
      <span class="tab-count">{Object.values(countryCounts).reduce((a, b) => a + b, 0)}</span>
    </button>
    {countries.map(c => (
      <button
        class:list={["country-tab", { disabled: !countryCounts[c.id] }]}
        data-country={c.id}
        disabled={!countryCounts[c.id]}
      >
        {c.label}
        <span class="tab-count">{countryCounts[c.id] || 0}</span>
      </button>
    ))}
  </div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
  .sea-map-container {
    margin: 2rem 0;
  }

  .map-wrapper {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
  }

  .country-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-top: 1.25rem;
  }

  .country-tab {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border-radius: 100px;
    font-size: 0.85rem;
    font-family: var(--font-sans);
    font-weight: 500;
    background: white;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .country-tab:hover:not(:disabled) {
    background: #e8f0fe;
    border-color: #aecbfa;
    color: var(--color-google-blue);
  }

  .country-tab.active {
    background: var(--color-google-blue);
    border-color: var(--color-google-blue);
    color: white;
  }

  .country-tab.active .tab-count {
    background: rgba(255, 255, 255, 0.25);
    color: white;
  }

  .country-tab:disabled {
    opacity: 0.4;
    cursor: not-allowed;
  }

  .tab-count {
    background: var(--color-bg-subtle);
    padding: 0.1rem 0.4rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .map-wrapper {
      display: none;
    }
  }
</style>

<script define:vars={{ countryCountsJSON }}>
  const countryCounts = JSON.parse(countryCountsJSON);

  const countryLocations = {
    'Vietnam':      { lat: 16.0, lng: 107.0 },
    'Thailand':     { lat: 15.0, lng: 101.0 },
    'Indonesia':    { lat: -2.5, lng: 118.0 },
    'Malaysia':     { lat: 4.0,  lng: 109.5 },
    'Philippines':  { lat: 13.0, lng: 122.0 },
    'Singapore':    { lat: 1.35, lng: 103.82 },
  };

  const countryColors = {
    'Vietnam':     '#4285f4',
    'Thailand':    '#ea4335',
    'Indonesia':   '#34a853',
    'Malaysia':    '#fbbc05',
    'Philippines': '#9334e6',
    'Singapore':   '#e8710a',
  };

  const countryFlags = {
    'Vietnam': '🇻🇳',
    'Thailand': '🇹🇭',
    'Indonesia': '🇮🇩',
    'Malaysia': '🇲🇾',
    'Philippines': '🇵🇭',
    'Singapore': '🇸🇬',
  };

  let activeCountry = 'All';
  let markers = [];
  let mapInstance = null;

  function initMap() {
    if (typeof window.L === 'undefined') return;

    const L = window.L;
    const map = L.map('sea-map', {
      center: [5, 110],
      zoom: 4,
      minZoom: 3,
      maxZoom: 7,
      scrollWheelZoom: false,
      zoomControl: true,
    });
    mapInstance = map;

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
      maxZoom: 7,
    }).addTo(map);

    // Add markers for each country
    Object.entries(countryLocations).forEach(([country, coords]) => {
      const count = countryCounts[country] || 0;
      if (count === 0) return;

      const color = countryColors[country] || '#4285f4';
      const flag = countryFlags[country] || '';

      const icon = L.divIcon({
        className: 'sea-marker',
        html: `<div style="
          background: ${color};
          color: white;
          border-radius: 50%;
          width: 40px;
          height: 40px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-weight: 700;
          font-size: 14px;
          font-family: 'DM Sans', sans-serif;
          box-shadow: 0 2px 8px rgba(0,0,0,0.3);
          border: 3px solid white;
          cursor: pointer;
          transition: transform 0.2s;
        ">${count}</div>`,
        iconSize: [40, 40],
        iconAnchor: [20, 20],
      });

      const marker = L.marker([coords.lat, coords.lng], { icon }).addTo(map);
      marker.bindPopup(
        `<div style="text-align:center;font-family:'DM Sans',sans-serif;">
          <strong style="font-size:14px;">${flag} ${country}</strong><br/>
          <span style="color:#137333;font-weight:600;">${count} success ${count === 1 ? 'story' : 'stories'}</span>
        </div>`,
        { className: 'sea-popup' }
      );

      marker.on('click', () => selectCountry(country));
      marker.countryId = country;
      markers.push(marker);
    });
  }

  // Tab clicks
  const tabs = document.getElementById('country-tabs');
  tabs?.querySelectorAll('.country-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const country = tab.getAttribute('data-country');
      if (country) selectCountry(country);
    });
  });

  function selectCountry(country) {
    if (activeCountry === country) country = 'All';
    activeCountry = country;

    // Update tabs
    tabs?.querySelectorAll('.country-tab').forEach(t => {
      t.classList.toggle('active', t.getAttribute('data-country') === country);
    });

    // Pan map to selected country
    if (mapInstance && country !== 'All' && countryLocations[country]) {
      const loc = countryLocations[country];
      mapInstance.flyTo([loc.lat, loc.lng], 6, { duration: 0.8 });
    } else if (mapInstance && country === 'All') {
      mapInstance.flyTo([5, 110], 4, { duration: 0.8 });
    }

    // Dispatch custom event for blog grid filtering
    document.dispatchEvent(new CustomEvent('country-filter', { detail: { country } }));
  }

  // Load Leaflet JS dynamically
  const script = document.createElement('script');
  script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
  script.onload = initMap;
  document.head.appendChild(script);
</script>
