---
interface Heading {
  text: string;
  slug: string;
  depth: number;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filteredHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<nav class="toc-sidebar hidden lg:block">
  <div class="sticky top-8">
    <p class="text-sm font-semibold text-gray-900 mb-3 uppercase tracking-wide">
      On this page
    </p>
    <ul class="space-y-1 text-sm border-l-2 border-gray-200">
      {filteredHeadings.map((heading) => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              "block py-1 text-gray-500 hover:text-accent transition-colors border-l-2 -ml-[2px]",
              "border-transparent hover:border-accent",
              heading.depth === 3 ? "pl-6" : "pl-4",
            ]}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .toc-sidebar {
    width: 240px;
    min-width: 240px;
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
    font-family: var(--font-sans);
  }

  .toc-sidebar a {
    text-decoration: none;
    line-height: 1.4;
  }
</style>
