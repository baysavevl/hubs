---
const base = import.meta.env.BASE_URL;
const currentPath = Astro.url.pathname;

function isActive(path: string) {
  if (path === base) return currentPath === base || currentPath === base.slice(0, -1);
  return currentPath.startsWith(path);
}
---

<header class="w-full border-b border-[var(--color-border)] bg-white/80 backdrop-blur-md sticky top-0 z-50">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
    <a href={base} class="flex items-center gap-2.5 group">
      <div class="flex gap-[3px]">
        <span class="block w-2.5 h-2.5 rounded-full bg-[var(--color-google-blue)] group-hover:scale-110 transition-transform"></span>
        <span class="block w-2.5 h-2.5 rounded-full bg-[var(--color-google-red)] group-hover:scale-110 transition-transform delay-[50ms]"></span>
        <span class="block w-2.5 h-2.5 rounded-full bg-[var(--color-google-yellow)] group-hover:scale-110 transition-transform delay-100"></span>
        <span class="block w-2.5 h-2.5 rounded-full bg-[var(--color-google-green)] group-hover:scale-110 transition-transform delay-150"></span>
      </div>
      <span class="text-base font-semibold tracking-tight text-[var(--color-text)]">
        Google Ads Solutions Architect
      </span>
    </a>
    <div class="flex gap-5 text-sm font-medium">
      <a
        href={base}
        class:list={[
          "transition-colors",
          isActive(base) && !isActive(`${base}projects`) && !isActive(`${base}success-story`) && !isActive(`${base}let-us-help`)
            ? "text-[var(--color-google-blue)]"
            : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Home
      </a>
      <a
        href={`${base}projects`}
        class:list={[
          "transition-colors",
          isActive(`${base}projects`)
            ? "text-[var(--color-google-blue)]"
            : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Knowledge Base
      </a>
      <a
        href={`${base}success-story`}
        class:list={[
          "transition-colors",
          isActive(`${base}success-story`)
            ? "text-[var(--color-google-blue)]"
            : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Success Stories
      </a>
      <a
        href={`${base}let-us-help`}
        class:list={[
          "transition-colors",
          isActive(`${base}let-us-help`)
            ? "text-[var(--color-google-blue)]"
            : "text-[var(--color-text-muted)] hover:text-[var(--color-text)]",
        ]}
      >
        Let Us Help
      </a>
    </div>
  </nav>
</header>
