---
const base = import.meta.env.BASE_URL;
---

<div class="chat-container" id="chatbot">
  <!-- Thread bar -->
  <div class="thread-bar">
    <div class="thread-tabs" id="thread-tabs"></div>
    <button class="thread-add" id="thread-add" title="New chat">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
    </button>
  </div>

  <!-- Messages -->
  <div class="chat-scroll" id="chat-scroll"></div>

  <!-- Input -->
  <div class="chat-input-area">
    <div class="chat-input-pill">
      <input type="text" id="chat-input" placeholder="Ask about Google Ads..." autocomplete="off" />
      <button id="chat-send" aria-label="Send">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="22" y1="2" x2="11" y2="13"></line>
          <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
        </svg>
      </button>
    </div>
    <p class="chat-foot">Google Ads Solutions Architect &middot; <a href={`${base}projects/google-ads/`}>Complete guide</a></p>
  </div>
</div>

<style>
  .chat-container {
    display: flex;
    flex-direction: column;
    height: 580px;
    border: 1px solid #e0e0e0;
    border-radius: 16px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  /* ═══ Thread bar ═══ */
  .thread-bar {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.5rem 0.75rem;
    background: #f8f9fa;
    border-bottom: 1px solid #e0e0e0;
    min-height: 42px;
  }

  .thread-tabs {
    display: flex;
    gap: 0.3rem;
    flex: 1;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .thread-tabs::-webkit-scrollbar { display: none; }

  .tab {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.65rem;
    border-radius: 8px;
    font-size: 0.73rem;
    font-family: var(--font-sans);
    color: #5f6368;
    background: #fff;
    border: 1px solid #dadce0;
    cursor: pointer;
    white-space: nowrap;
    max-width: 140px;
    transition: all 0.12s;
    flex-shrink: 0;
  }

  .tab:hover { border-color: #bbb; }

  .tab.active {
    background: #1a73e8;
    border-color: #1a73e8;
    color: #fff;
  }

  .tab-label {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .tab-x {
    flex-shrink: 0;
    width: 14px; height: 14px;
    border-radius: 50%;
    border: none;
    background: transparent;
    color: inherit;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.6rem;
    padding: 0;
    opacity: 0.6;
    transition: all 0.1s;
    line-height: 1;
  }

  .tab-x:hover {
    opacity: 1;
    background: rgba(0,0,0,0.1);
  }

  .tab.active .tab-x:hover {
    background: rgba(255,255,255,0.25);
  }

  .thread-add {
    flex-shrink: 0;
    width: 30px; height: 30px;
    border-radius: 8px;
    border: 1px solid #dadce0;
    background: #fff;
    color: #1a73e8;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.12s;
  }

  .thread-add:hover {
    background: #e8f0fe;
    border-color: #aecbfa;
  }

  /* ═══ Message scroll ═══ */
  .chat-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 1.25rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    scroll-behavior: smooth;
    background: #fafafa;
  }

  /* ═══ Message row ═══ */
  .msg-row {
    display: flex;
    gap: 0.5rem;
    align-items: flex-end;
    margin-bottom: 4px;
    animation: msgIn 0.25s ease;
  }

  /* Speaker change = bigger gap */
  .msg-row.gap-top {
    margin-top: 16px;
  }

  .msg-row.user {
    flex-direction: row-reverse;
  }

  @keyframes msgIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══ Avatar ═══ */
  .msg-ava {
    flex-shrink: 0;
    width: 32px; height: 32px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 600;
    font-family: var(--font-sans);
  }

  .msg-ava.bot {
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
  }

  .msg-ava.user {
    background: #1a73e8;
    color: #fff;
  }

  /* Hide avatar for consecutive same-speaker messages */
  .msg-row.no-ava .msg-ava {
    visibility: hidden;
  }

  /* ═══ Bubbles ═══ */
  .msg-bub {
    max-width: 75%;
    padding: 0.75rem 1rem;
    font-size: 0.88rem;
    line-height: 1.7;
    font-family: var(--font-sans);
    word-wrap: break-word;
  }

  /* Bot bubble: left, light grey, rounded except bottom-left */
  .msg-bub.bot {
    background: #f3f4f6;
    color: #1f2937;
    border: 1px solid #e5e7eb;
    border-radius: 12px 12px 12px 0;
  }

  /* User bubble: right, blue, rounded except bottom-right */
  .msg-bub.user {
    background: #1a73e8;
    color: #fff;
    border: none;
    border-radius: 12px 12px 0 12px;
  }

  /* ═══ Rich text inside bot bubbles ═══ */
  .msg-bub.bot p { margin: 0 0 0.5rem; }
  .msg-bub.bot p:last-child { margin-bottom: 0; }
  .msg-bub.bot strong { font-weight: 600; color: #111827; }
  .msg-bub.bot em { color: #6b7280; }
  .msg-bub.bot code {
    font-family: var(--font-mono); font-size: 0.84em;
    background: #e5e7eb; padding: 0.12em 0.35em; border-radius: 4px;
  }
  .msg-bub.bot ul, .msg-bub.bot ol {
    margin: 0.4rem 0; padding-left: 1.2rem;
  }
  .msg-bub.bot li { margin-bottom: 0.25rem; line-height: 1.6; }
  .msg-bub.bot li:last-child { margin-bottom: 0; }

  /* ═══ Links ═══ */
  .msg-links {
    display: flex; flex-wrap: wrap; gap: 0.3rem; margin-top: 0.6rem;
  }
  .msg-lnk {
    display: inline-flex; align-items: center; gap: 0.2rem;
    font-size: 0.76rem; color: #1a73e8; text-decoration: none;
    font-weight: 500; padding: 0.2rem 0.5rem; border-radius: 6px;
    background: #dbeafe; transition: background 0.12s;
  }
  .msg-lnk:hover { background: #bfdbfe; }

  /* ═══ Related ═══ */
  .msg-rel {
    margin-top: 0.55rem; padding-top: 0.45rem; border-top: 1px solid #e5e7eb;
  }
  .msg-rel-h { font-size: 0.68rem; color: #9ca3af; margin: 0 0 0.2rem; font-weight: 500; }
  .msg-rel-btn {
    display: block; background: none; border: none; color: #1a73e8;
    font-size: 0.78rem; font-family: var(--font-sans); cursor: pointer;
    padding: 0.12rem 0; text-align: left;
  }
  .msg-rel-btn:hover { text-decoration: underline; }

  /* ═══ Chips ═══ */
  .msg-chips {
    display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.6rem;
  }
  .msg-chip {
    background: #fff; border: 1px solid #d1d5db; border-radius: 100px;
    padding: 0.3rem 0.7rem; font-size: 0.76rem; font-family: var(--font-sans);
    color: #1a73e8; cursor: pointer; transition: all 0.12s; font-weight: 500;
  }
  .msg-chip:hover { background: #eff6ff; border-color: #93c5fd; }

  /* ═══ Typing ═══ */
  .typing-dots { display: flex; gap: 4px; padding: 0.25rem 0; }
  .typing-dots span {
    width: 7px; height: 7px; border-radius: 50%;
    animation: tdot 1.3s infinite;
  }
  .typing-dots span:nth-child(1) { background: #4285f4; }
  .typing-dots span:nth-child(2) { background: #ea4335; animation-delay: 0.2s; }
  .typing-dots span:nth-child(3) { background: #fbbc05; animation-delay: 0.4s; }
  @keyframes tdot {
    0%,80%,100% { transform: scale(0.8); opacity: 0.4; }
    40% { transform: scale(1.1); opacity: 1; }
  }

  /* ═══ Streaming cursor ═══ */
  .s-cursor {
    display: inline-block; width: 2px; height: 1em; background: #1a73e8;
    margin-left: 1px; vertical-align: text-bottom;
    animation: blink 0.7s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* ═══ Input ═══ */
  .chat-input-area {
    padding: 0.65rem 1rem 0.55rem;
    border-top: 1px solid #e0e0e0;
    background: #fff;
  }

  .chat-input-pill {
    display: flex; align-items: center; gap: 0.5rem;
    background: #f3f4f6; border: 1.5px solid transparent;
    border-radius: 100px; padding: 0.45rem 0.55rem 0.45rem 1.1rem;
    transition: all 0.2s;
  }

  .chat-input-pill:focus-within {
    background: #fff; border-color: #1a73e8;
    box-shadow: 0 0 0 3px rgba(26,115,232,0.12);
  }

  #chat-input {
    flex: 1; border: none; background: none; font-size: 0.88rem;
    font-family: var(--font-sans); color: #1f2937; outline: none;
  }
  #chat-input::placeholder { color: #9ca3af; }

  #chat-send {
    background: #1a73e8; border: none; border-radius: 50%;
    width: 34px; height: 34px; display: flex; align-items: center;
    justify-content: center; color: white; cursor: pointer;
    transition: background 0.12s, transform 0.12s; flex-shrink: 0;
  }
  #chat-send:hover { background: #1557b0; transform: scale(1.05); }

  .chat-foot {
    font-size: 0.66rem; color: #9ca3af; text-align: center; margin: 0.3rem 0 0;
  }
  .chat-foot a { color: #1a73e8; text-decoration: none; }
</style>

<script>
  import { ChatEngine } from '../scripts/chat-engine.js';

  const STORE = 'gads-chat-v4', MAX = 5, TTL = 10 * 60 * 1000;
  let engine = null, threads = [], activeId = null;

  // ── Storage ──
  function load() {
    try {
      const raw = localStorage.getItem(STORE);
      if (!raw) return [];
      return JSON.parse(raw).filter(t => Date.now() - t.ts < TTL);
    } catch { return []; }
  }
  function save() { try { localStorage.setItem(STORE, JSON.stringify(threads)); } catch {} }
  function gid() { return 't' + Date.now().toString(36) + Math.random().toString(36).slice(2, 5); }

  async function initEngine() {
    try {
      const r = await fetch(import.meta.env.BASE_URL + 'data/knowledge-base.json');
      engine = new ChatEngine(await r.json());
    } catch (e) { console.warn('KB:', e); }
  }

  // ── Helpers ──
  function esc(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
  function md(text) {
    const blocks = text.split(/\n\n+/); let h = '';
    for (const b of blocks) {
      const t = b.trim(); if (!t) continue;
      const L = t.split('\n');
      const bul = L.every(l => /^\s*[-*•]\s/.test(l.trim()));
      const num = L.every(l => /^\s*\d+[.)]\s/.test(l.trim()));
      if (bul) h += '<ul>' + L.map(l => `<li>${fm(l.trim().replace(/^[-*•]\s+/, ''))}</li>`).join('') + '</ul>';
      else if (num) h += '<ol>' + L.map(l => `<li>${fm(l.trim().replace(/^\d+[.)]\s+/, ''))}</li>`).join('') + '</ol>';
      else h += `<p>${L.map(l => fm(l.trim())).join('<br>')}</p>`;
    }
    return h;
  }
  function fm(t) {
    return t.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
            .replace(/`(.+?)`/g, '<code>$1</code>');
  }

  const googleG = `<svg viewBox="0 0 48 48" width="20" height="20"><path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/><path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/><path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/><path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/></svg>`;
  const scr = () => document.getElementById('chat-scroll');
  let lastSpeaker = null;

  // ── Render messages ──
  function addBot(html, opts = {}) {
    const row = document.createElement('div');
    const isNewSpeaker = lastSpeaker !== 'bot';
    row.className = 'msg-row bot' + (isNewSpeaker ? ' gap-top' : ' no-ava');
    if (lastSpeaker === null) row.classList.remove('gap-top'); // first message
    lastSpeaker = 'bot';

    let extra = '';
    if (opts.links?.length) extra += '<div class="msg-links">' + opts.links.map(l => `<a href="${l.url}" class="msg-lnk">${esc(l.text)}</a>`).join('') + '</div>';
    if (opts.related?.length) extra += '<div class="msg-rel"><p class="msg-rel-h">Related</p>' + opts.related.map(r => `<button class="msg-rel-btn" data-q="${esc(r.question)}">${esc(r.question)}</button>`).join('') + '</div>';
    let chips = '';
    if (opts.chips) {
      chips = `<div class="msg-chips" id="msg-chips">
        <button class="msg-chip" data-q="How do I set up my first campaign?">First campaign</button>
        <button class="msg-chip" data-q="Which campaign type should I choose?">Campaign types</button>
        <button class="msg-chip" data-q="What bidding strategy should I use?">Bidding strategy</button>
        <button class="msg-chip" data-q="How do I set up conversion tracking?">Conversion tracking</button>
        <button class="msg-chip" data-q="Tell me about success stories">Success stories</button>
      </div>`;
    }

    row.innerHTML = `<div class="msg-ava bot">${googleG}</div><div class="msg-bub bot">${html}${extra}${chips}</div>`;
    scr().appendChild(row);
    scr().scrollTop = scr().scrollHeight;
    row.querySelectorAll('.msg-chip').forEach(c => c.addEventListener('click', () => handleQ(c.dataset.q)));
    row.querySelectorAll('.msg-rel-btn').forEach(b => b.addEventListener('click', () => handleQ(b.dataset.q)));
  }

  async function addBotStream(raw, opts = {}) {
    const isNewSpeaker = lastSpeaker !== 'bot';
    const row = document.createElement('div');
    row.className = 'msg-row bot' + (isNewSpeaker ? ' gap-top' : ' no-ava');
    lastSpeaker = 'bot';

    row.innerHTML = `<div class="msg-ava bot">${googleG}</div><div class="msg-bub bot"><span class="s-tgt"></span><span class="s-cursor"></span></div>`;
    scr().appendChild(row);

    const tgt = row.querySelector('.s-tgt');
    const cur = row.querySelector('.s-cursor');
    const words = raw.split(/(\s+)/);
    let acc = '';
    for (let i = 0; i < words.length; i++) {
      acc += words[i];
      tgt.innerHTML = md(acc);
      scr().scrollTop = scr().scrollHeight;
      if (words[i].trim()) await new Promise(r => setTimeout(r, 15 + Math.random() * 10));
    }
    cur.remove();

    let extra = '';
    if (opts.links?.length) extra += '<div class="msg-links">' + opts.links.map(l => `<a href="${l.url}" class="msg-lnk">${esc(l.text)}</a>`).join('') + '</div>';
    if (opts.related?.length) extra += '<div class="msg-rel"><p class="msg-rel-h">Related</p>' + opts.related.map(r => `<button class="msg-rel-btn" data-q="${esc(r.question)}">${esc(r.question)}</button>`).join('') + '</div>';
    row.querySelector('.msg-bub').innerHTML = md(raw) + extra;
    scr().scrollTop = scr().scrollHeight;
    row.querySelectorAll('.msg-rel-btn').forEach(b => b.addEventListener('click', () => handleQ(b.dataset.q)));
  }

  function addUser(text) {
    const isNewSpeaker = lastSpeaker !== 'user';
    const row = document.createElement('div');
    row.className = 'msg-row user' + (isNewSpeaker ? ' gap-top' : ' no-ava');
    lastSpeaker = 'user';
    row.innerHTML = `<div class="msg-ava user">Y</div><div class="msg-bub user">${esc(text)}</div>`;
    scr().appendChild(row);
    scr().scrollTop = scr().scrollHeight;
  }

  function showTyping() {
    const row = document.createElement('div');
    row.className = 'msg-row bot gap-top'; row.id = 'typing-row';
    lastSpeaker = 'bot';
    row.innerHTML = `<div class="msg-ava bot">${googleG}</div><div class="msg-bub bot"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
    scr().appendChild(row); scr().scrollTop = scr().scrollHeight;
  }
  function hideTyping() {
    document.getElementById('typing-row')?.remove();
  }

  // ── Thread tabs ──
  function renderTabs() {
    const container = document.getElementById('thread-tabs');
    container.innerHTML = '';
    for (const t of threads) {
      const tab = document.createElement('div');
      tab.className = 'tab' + (t.id === activeId ? ' active' : '');
      tab.innerHTML = `<span class="tab-label">${esc(t.title || 'New chat')}</span><button class="tab-x" title="Delete">&times;</button>`;
      tab.querySelector('.tab-label').addEventListener('click', () => switchThread(t.id));
      tab.querySelector('.tab-x').addEventListener('click', (e) => { e.stopPropagation(); deleteThread(t.id); });
      container.appendChild(tab);
    }
  }

  function getThread(id) { return threads.find(t => t.id === id); }

  function newThread() {
    if (threads.length >= MAX) { alert(`Max ${MAX} chats. Close one first.`); return; }
    const t = { id: gid(), title: '', messages: [], ts: Date.now() };
    threads.push(t);
    activeId = t.id;
    save(); renderChat(); renderTabs();
    document.getElementById('chat-input').focus();
  }

  function deleteThread(id) {
    threads = threads.filter(t => t.id !== id);
    if (activeId === id) {
      if (threads.length) activeId = threads[0].id;
      else { const t = { id: gid(), title: '', messages: [], ts: Date.now() }; threads.push(t); activeId = t.id; }
    }
    save(); renderChat(); renderTabs();
  }

  function switchThread(id) {
    if (id === activeId) return;
    activeId = id;
    renderChat(); renderTabs();
  }

  function renderChat() {
    scr().innerHTML = '';
    lastSpeaker = null;
    const t = getThread(activeId);
    if (!t || !t.messages.length) {
      addBot('<p>Hi, I\'m your <strong>Google Ads Solutions Architect</strong>. Ask me about campaigns, bidding, tracking, optimization, or our SEA success stories.</p>', { chips: true });
    } else {
      for (const m of t.messages) {
        if (m.role === 'user') addUser(m.text);
        else addBot(m.html);
      }
    }
  }

  // ── Handle query ──
  async function handleQ(q) {
    const t = getThread(activeId); if (!t) return;
    addUser(q);
    t.messages.push({ role: 'user', text: q });
    if (!t.title) { t.title = q.length > 28 ? q.slice(0, 28) + '…' : q; renderTabs(); }

    const chips = document.getElementById('msg-chips');
    if (chips) chips.style.display = 'none';

    showTyping();
    await new Promise(r => setTimeout(r, 200 + Math.random() * 250));
    hideTyping();

    if (!engine) {
      const h = '<p>Still loading. Try again shortly.</p>';
      addBot(h); t.messages.push({ role: 'bot', html: h }); t.ts = Date.now(); save(); return;
    }

    const res = engine.getResponse(q);
    await addBotStream(res.answer, { links: res.links, related: res.related });
    t.messages.push({ role: 'bot', html: md(res.answer) }); t.ts = Date.now(); save();
  }

  // ── Boot ──
  initEngine();
  threads = load();
  if (!threads.length) { const t = { id: gid(), title: '', messages: [], ts: Date.now() }; threads.push(t); }
  activeId = threads[0].id;
  save(); renderChat(); renderTabs();

  document.getElementById('thread-add').addEventListener('click', newThread);
  const inp = document.getElementById('chat-input'), btn = document.getElementById('chat-send');
  function sub() { const q = inp.value.trim(); if (!q) return; inp.value = ''; handleQ(q); }
  btn.addEventListener('click', sub);
  inp.addEventListener('keydown', e => { if (e.key === 'Enter') sub(); });
</script>
